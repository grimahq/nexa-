# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL=""
# SUPABASE_PUBLISHABLE_KEY: The anon/public key of your Supabase project.
SUPABASE_PUBLISHABLE_KEY=""
# SUPABASE_SERVICE_ROLE_KEY: The service role key of your Supabase project (keep secret!).
SUPABASE_SERVICE_ROLE_KEY=""

# VITE_SUPABASE_URL: The URL of your Supabase project (exposed to client).
VITE_SUPABASE_URL=""
# VITE_SUPABASE_PUBLISHABLE_KEY: The anon/public key of your Supabase project (exposed to client).
VITE_SUPABASE_PUBLISHABLE_KEY=""
