{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and system-wide settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "staff"] },
        "avatar": { "type": "string" },
        "stores": { "type": "array", "items": { "type": "string" } },
        "onboarding": {
          "type": "object",
          "properties": {
            "businessType": { "type": "string" },
            "categories": { "type": "array", "items": { "type": "string" } },
            "storeName": { "type": "string" },
            "storePhone": { "type": "string" },
            "storeAddress": { "type": "string" },
            "receiptFooter": { "type": "string" },
            "taxRate": { "type": "number" },
            "brandColor": { "type": "string" },
            "logoUrl": { "type": "string" }
          }
        }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Item": {
      "title": "Inventory Item",
      "description": "A product or material in inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "discontinued", "draft"] },
        "unit": { "type": "string" },
        "unitType": { "type": "string", "enum": ["count", "weight", "length", "volume"] },
        "currentStock": { "type": "number" },
        "reorderPoint": { "type": "number" },
        "reorderQuantity": { "type": "number" },
        "costPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "locationId": { "type": "string" },
        "supplierId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "emoji": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isEcommerceEnabled": { "type": "boolean" },
        "affiliateCommission": { "type": "number" },
        "unitConversions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "unitId": { "type": "string" },
              "multiplier": { "type": "number" },
              "priceNgn": { "type": "number" }
            }
          }
        },
        "customFields": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sku", "name", "status", "unit", "currentStock", "sellingPrice"]
    },
    "Category": {
      "title": "Category",
      "description": "Item categorization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "parentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "SaleTransaction": {
      "title": "Sale Transaction",
      "description": "Record of a completed sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "itemName": { "type": "string" },
              "sku": { "type": "string" },
              "quantity": { "type": "number" },
              "unit": { "type": "string" },
              "multiplier": { "type": "number" },
              "unitPriceNgn": { "type": "number" }
            }
          }
        },
        "totalNgn": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items", "totalNgn", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "amount", "category", "date"]
    },
    "Refund": {
      "title": "Refund",
      "description": "Refund transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "saleId": { "type": "string" },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "quantity": { "type": "number" },
        "amountNgn": { "type": "number" },
        "reason": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "saleId", "amountNgn"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or stock alert.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "link": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "type", "title", "message", "read"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "SubscriptionPlan": {
      "title": "Subscription Plan",
      "description": "Single source of truth for what each tier unlocks.",
      "type": "object",
      "properties": {
        "planId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "billingCycle": { "type": "string", "enum": ["monthly", "yearly"] },
        "featureFlags": {
          "type": "object",
          "properties": {
            "pricingMode": { "type": "boolean" },
            "crossBranchVisibility": { "type": "boolean" },
            "b2bMarketplace": { "type": "boolean" },
            "maxBranches": { "type": "number" }
          }
        },
        "isActive": { "type": "boolean" },
        "sortOrder": { "type": "number" }
      },
      "required": ["planId", "name", "price", "billingCycle", "featureFlags", "isActive", "sortOrder"]
    },
    "SubscriptionEvent": {
      "title": "Subscription Event",
      "description": "An audit log of subscription changes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "eventType": { "type": "string" },
        "fromPlan": { "type": "string" },
        "toPlan": { "type": "string" },
        "actorId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      },
      "required": ["id", "storeId", "eventType", "actorId", "timestamp"]
    },
    "QRLeadEvent": {
      "title": "QR Lead Event",
      "description": "Log of QR scan or CTA click event for attribution tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "qrSourceId": { "type": "string" },
        "storeId": { "type": "string" },
        "branchId": { "type": "string", "nullable": true },
        "eventType": { "type": "string", "enum": ["scan", "cta_click"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "qrSourceId", "storeId", "eventType", "timestamp"]
    },
    "SupportChat": {
      "title": "Support Chat",
      "description": "Customer support chat session with AI agents or live agents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": { "type": "string", "enum": ["customer", "agent", "staff"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "customerName", "status", "messages"]
    },
    "Agent": {
      "title": "Agent",
      "description": "NEXAOS Agent profile",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "passwordHash": { "type": "string" },
        "referralCode": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "dateJoined": { "type": "string" },
        "bankDetails": {
          "type": "object",
          "properties": {
            "bankName": { "type": "string" },
            "accountNumber": { "type": "string" },
            "accountName": { "type": "string" }
          }
        }
      },
      "required": ["agentId", "fullName", "email", "status", "dateJoined", "referralCode"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Referral record linking agent to merchant",
      "type": "object",
      "properties": {
        "referralId": { "type": "string" },
        "agentId": { "type": "string" },
        "storeId": { "type": "string" },
        "referralSource": { "type": "string", "enum": ["code", "link"] },
        "signupDate": { "type": "string" },
        "subscriptionActivatedDate": { "type": "string" },
        "currentPlanId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "converted", "churned"] }
      },
      "required": ["referralId", "agentId", "storeId", "referralSource", "signupDate", "status"]
    },
    "AgentEarning": {
      "title": "Agent Earning",
      "description": "Earning entry for agent from referred subscription payment",
      "type": "object",
      "properties": {
        "earningId": { "type": "string" },
        "agentId": { "type": "string" },
        "referralId": { "type": "string" },
        "type": { "type": "string", "enum": ["onboarding_bonus", "recurring_residual", "clawback"] },
        "amount": { "type": "number" },
        "relatedSubscriptionEventId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "reversed"] },
        "createdAt": { "type": "string" },
        "paidAt": { "type": "string" }
      },
      "required": ["earningId", "agentId", "referralId", "type", "amount", "status", "createdAt"]
    },
    "CommissionRule": {
      "title": "Commission Rule",
      "description": "Dynamic rules for calculating commission payments",
      "type": "object",
      "properties": {
        "ruleId": { "type": "string" },
        "onboardingBonusAmount": { "type": "number" },
        "onboardingBonusType": { "type": "string", "enum": ["fixed", "percentage_of_first_payment"] },
        "recurringResidualPercentage": { "type": "number" },
        "recurringResidualDurationMonths": { "type": "number" },
        "clawbackWindowDays": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["ruleId", "onboardingBonusAmount", "onboardingBonusType", "recurringResidualPercentage", "clawbackWindowDays", "isActive"]
    },
    "RetentionTrigger": {
      "title": "Retention Trigger",
      "description": "Automated retention trigger configurations",
      "type": "object",
      "properties": {
        "triggerId": { "type": "string" },
        "name": { "type": "string" },
        "condition": { "type": "string", "enum": ["no_sales_logged_in_N_days", "trial_ending_in_N_days", "subscription_past_due", "onboarding_incomplete_after_N_days", "low_stock_no_reorder"] },
        "thresholdValue": { "type": "number" },
        "channel": { "type": "string", "enum": ["whatsapp", "sms", "in_app"] },
        "messageTemplate": { "type": "string" },
        "isActive": { "type": "boolean" },
        "cooldownDays": { "type": "number" }
      },
      "required": ["triggerId", "name", "condition", "thresholdValue", "channel", "messageTemplate", "isActive", "cooldownDays"]
    },
    "RetentionEvent": {
      "title": "Retention Event",
      "description": "Log of fired retention triggers and messages",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "storeId": { "type": "string" },
        "triggerId": { "type": "string" },
        "channel": { "type": "string", "enum": ["whatsapp", "sms", "in_app"] },
        "sentAt": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "failed", "responded"] },
        "responseAt": { "type": "string" },
        "agentId": { "type": "string" },
        "meta": { "type": "object" }
      },
      "required": ["eventId", "storeId", "triggerId", "channel", "sentAt", "status"]
    },
    "CreditCustomer": {
      "title": "Credit Customer",
      "description": "Customer credit accounts and debt transactions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerEmail": { "type": "string" },
        "balanceNgn": { "type": "number" },
        "transactions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["credit", "payment"] },
              "amountNgn": { "type": "number" },
              "saleId": { "type": "string" },
              "notes": { "type": "string" },
              "createdAt": { "type": "string" }
            }
          }
        },
        "storeId": { "type": "string" }
      },
      "required": ["id", "customerName", "customerPhone", "balanceNgn", "transactions", "storeId"]
    }
  },
  "firestore": {
    "credits": {
        "schema": "CreditCustomer",
        "description": "Credit and debt accounts for customers."
    },
    "stores": {
        "schema": "object",
        "description": "Multi-tenant store configurations and subscription details."
    },
    "subscriptionPlans": {
        "schema": "SubscriptionPlan",
        "description": "List of available subscription tiers and feature-flags."
    },
    "subscriptionEvents": {
        "schema": "SubscriptionEvent",
        "description": "Audit trail logs for store subscription changes."
    },
    "qrLeadEvents": {
        "schema": "QRLeadEvent",
        "description": "Log of QR code scans and CTA click actions."
    },
    "users": {
        "schema": "User",
        "description": "Root collection for users."
    },
    "items": {
        "schema": "Item",
        "description": "Global items collection."
    },
    "categories": {
        "schema": "Category",
        "description": "Product categories."
    },
    "sales": {
        "schema": "SaleTransaction",
        "description": "Sales records."
    },
    "expenses": {
        "schema": "Expense",
        "description": "Business expenses."
    },
    "refunds": {
        "schema": "Refund",
        "description": "Refund records."
    },
    "notifications": {
        "schema": "Notification",
        "description": "System alerts."
    },
    "customers": {
        "schema": "Customer",
        "description": "Customer records."
    },
    "support_chats": {
        "schema": "SupportChat",
        "description": "Customer support chat logs and AI conversation state."
    },
    "agents": {
        "schema": "Agent",
        "description": "Agent records and profile data."
    },
    "referrals": {
        "schema": "Referral",
        "description": "Attribution mapping of merchants to agents."
    },
    "agentEarnings": {
        "schema": "AgentEarning",
        "description": "Income ledgers for agents."
    },
    "commissionRules": {
        "schema": "CommissionRule",
        "description": "Configurable parameters for payouts."
    },
    "retentionTriggers": {
        "schema": "RetentionTrigger",
        "description": "Automated system conditions that check merchant activity and trigger alerts."
    },
    "retentionEvents": {
        "schema": "RetentionEvent",
        "description": "Events and alert delivery records representing fired retention actions."
    }
  }
}
